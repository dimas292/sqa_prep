<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SQA Learn — Software Quality Assurance</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d14;
    --bg2: #14141f;
    --bg3: #1c1c2e;
    --bg4: #22223a;
    --surface: #2a2a44;
    --border: rgba(160,140,255,0.12);
    --border-h: rgba(160,140,255,0.28);
    --accent: #8b7cf8;
    --accent2: #a78bfa;
    --accent3: #c4b5fd;
    --gold: #f5c842;
    --teal: #34d399;
    --coral: #fb7185;
    --sky: #60a5fa;
    --text: #e8e4ff;
    --text2: #a89dc4;
    --text3: #6b6285;
    --font-head: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --r: 10px;
    --r2: 16px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.75;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── LAYOUT ── */
  .shell { display: flex; min-height: 100vh; }
  .sidebar {
    width: 260px;
    min-width: 260px;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }
  .main { flex: 1; overflow-x: hidden; }

  /* ── SIDEBAR ── */
  .logo {
    padding: 24px 20px 18px;
    border-bottom: 1px solid var(--border);
  }
  .logo-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--accent) 0%, #6d5bd4 100%);
    color: #fff;
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 3px 9px;
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .logo h1 {
    font-family: var(--font-head);
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }
  .logo p {
    font-size: 12px;
    color: var(--text3);
    margin-top: 3px;
  }
  .nav-section { padding: 14px 12px 6px; }
  .nav-section-title {
    font-family: var(--font-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--text3);
    padding: 0 8px;
    margin-bottom: 6px;
    text-transform: uppercase;
  }
  .cat-group { margin-bottom: 4px; }
  .cat-btn {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: var(--r);
    color: var(--text2);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    text-align: left;
    transition: all .18s;
  }
  .cat-btn:hover { background: var(--bg3); color: var(--text); }
  .cat-btn.active { background: rgba(139,124,248,0.15); color: var(--accent3); }
  .cat-icon {
    width: 28px; height: 28px;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }
  .cat-chevron {
    margin-left: auto;
    font-size: 11px;
    transition: transform .18s;
    color: var(--text3);
  }
  .cat-btn.open .cat-chevron { transform: rotate(90deg); }
  .parts-list {
    display: none;
    padding: 2px 0 4px 46px;
  }
  .parts-list.open { display: block; }
  .part-btn {
    display: block;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 5px 10px;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 12.5px;
    color: var(--text3);
    transition: all .15s;
  }
  .part-btn:hover { color: var(--text2); background: var(--bg3); }
  .part-btn.active { color: var(--accent2); font-weight: 500; }
  .sidebar-footer {
    margin-top: auto;
    padding: 14px 16px;
    border-top: 1px solid var(--border);
  }
  .progress-bar-wrap {
    background: var(--bg3);
    border-radius: 4px;
    height: 5px;
    overflow: hidden;
    margin-top: 6px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--teal));
    border-radius: 4px;
    transition: width .4s ease;
    width: 0%;
  }
  .progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text3);
    margin-bottom: 4px;
  }

  /* ── HEADER ── */
  .page-header {
    padding: 36px 44px 28px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
  }
  .breadcrumb {
    font-size: 12px;
    color: var(--text3);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .breadcrumb span { color: var(--accent2); }
  .page-header h2 {
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 800;
    color: var(--text);
    line-height: 1.25;
  }
  .page-header .meta {
    margin-top: 8px;
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11.5px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.3px;
  }
  .tag-level { background: rgba(245,200,66,0.12); color: var(--gold); }
  .tag-time  { background: rgba(52,211,153,0.1); color: var(--teal); }
  .tag-cat   { background: rgba(139,124,248,0.14); color: var(--accent2); }

  /* ── CONTENT ── */
  .content-area { padding: 36px 44px 60px; max-width: 800px; }

  /* ── PART CARD ── */
  .part-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .part-num {
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--text3);
    background: var(--bg3);
    padding: 3px 9px;
    border-radius: 4px;
  }
  .part-title {
    font-family: var(--font-head);
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }
  .material-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r2);
    padding: 24px 28px;
    margin-bottom: 20px;
    line-height: 1.8;
    color: var(--text2);
    font-size: 14.5px;
  }
  .material-card p { margin-bottom: 12px; }
  .material-card p:last-child { margin-bottom: 0; }
  .material-card ul {
    padding-left: 20px;
    margin: 10px 0;
  }
  .material-card ul li { margin-bottom: 6px; }
  .material-card strong { color: var(--text); font-weight: 500; }

  /* ── HIGHLIGHT / TERM ── */
  .term {
    display: inline;
    background: rgba(139,124,248,0.18);
    border-bottom: 1.5px solid var(--accent);
    color: var(--accent3);
    padding: 1px 3px;
    border-radius: 3px;
    cursor: pointer;
    font-weight: 500;
    transition: background .15s;
    position: relative;
  }
  .term:hover { background: rgba(139,124,248,0.32); }
  .term[data-type="process"] {
    background: rgba(52,211,153,0.12);
    border-bottom-color: var(--teal);
    color: #6ee7b7;
  }
  .term[data-type="tool"] {
    background: rgba(96,165,250,0.12);
    border-bottom-color: var(--sky);
    color: #93c5fd;
  }
  .term[data-type="metric"] {
    background: rgba(245,200,66,0.1);
    border-bottom-color: var(--gold);
    color: #fde68a;
  }
  .term[data-type="error"] {
    background: rgba(251,113,133,0.1);
    border-bottom-color: var(--coral);
    color: #fda4af;
  }

  /* ── TOOLTIP ── */
  .tooltip-overlay {
    position: fixed;
    inset: 0;
    z-index: 900;
    pointer-events: none;
  }
  .tooltip-box {
    position: fixed;
    z-index: 1000;
    background: var(--bg4);
    border: 1px solid var(--border-h);
    border-radius: var(--r2);
    padding: 14px 18px;
    max-width: 300px;
    min-width: 200px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    pointer-events: none;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity .2s, transform .2s;
  }
  .tooltip-box.show {
    opacity: 1;
    transform: translateY(0);
  }
  .tooltip-label {
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .tooltip-label.concept { color: var(--accent2); }
  .tooltip-label.process { color: var(--teal); }
  .tooltip-label.tool    { color: var(--sky); }
  .tooltip-label.metric  { color: var(--gold); }
  .tooltip-label.error   { color: var(--coral); }
  .tooltip-term {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
    font-family: var(--font-head);
  }
  .tooltip-def {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.6;
  }

  /* ── LEGEND ── */
  .legend-bar {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    padding: 14px 20px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r);
    margin-bottom: 24px;
    font-size: 12px;
    color: var(--text3);
    align-items: center;
  }
  .legend-bar strong { color: var(--text2); font-size: 11.5px; margin-right: 6px; }
  .legend-dot {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    cursor: default;
  }
  .ld {
    width: 9px; height: 9px; border-radius: 50%;
  }

  /* ── QUIZ ── */
  .quiz-section {
    margin-top: 28px;
  }
  .quiz-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .quiz-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent), #6d5bd4);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 17px;
  }
  .quiz-header h3 {
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }
  .quiz-header p {
    font-size: 12px;
    color: var(--text3);
  }
  .quiz-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r2);
    padding: 24px 28px;
    margin-bottom: 14px;
  }
  .quiz-card.answered { border-color: var(--border-h); }
  .quiz-q {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 14px;
    line-height: 1.6;
  }
  .quiz-q .q-num {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent2);
    background: rgba(139,124,248,0.14);
    padding: 2px 7px;
    border-radius: 4px;
    margin-right: 8px;
    vertical-align: 1px;
  }
  .options { display: flex; flex-direction: column; gap: 8px; }
  .option-btn {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 11px 15px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--r);
    cursor: pointer;
    text-align: left;
    color: var(--text2);
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.5;
    transition: all .15s;
  }
  .option-btn:hover:not(:disabled) { border-color: var(--border-h); background: var(--surface); color: var(--text); }
  .option-btn:disabled { cursor: default; }
  .option-btn.correct { background: rgba(52,211,153,0.1); border-color: rgba(52,211,153,0.4); color: #6ee7b7; }
  .option-btn.wrong   { background: rgba(251,113,133,0.1); border-color: rgba(251,113,133,0.35); color: #fda4af; }
  .opt-circle {
    width: 20px; height: 20px; min-width: 20px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    font-weight: 700;
    margin-top: 1px;
  }
  .quiz-feedback {
    margin-top: 12px;
    padding: 11px 15px;
    border-radius: var(--r);
    font-size: 13px;
    display: none;
    line-height: 1.6;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.ok { background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.2); color: #6ee7b7; }
  .quiz-feedback.no { background: rgba(251,113,133,0.08); border: 1px solid rgba(251,113,133,0.2); color: #fda4af; }

  /* ── SCORE BANNER ── */
  .score-banner {
    display: none;
    margin-top: 18px;
    padding: 18px 22px;
    border-radius: var(--r2);
    border: 1px solid var(--border-h);
    background: var(--bg3);
    align-items: center;
    gap: 16px;
  }
  .score-banner.show { display: flex; }
  .score-big {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 800;
    min-width: 80px;
    text-align: center;
    line-height: 1;
  }
  .score-big.great { color: var(--teal); }
  .score-big.ok    { color: var(--gold); }
  .score-big.poor  { color: var(--coral); }
  .score-meta { flex: 1; }
  .score-meta strong {
    display: block;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 2px;
  }
  .score-meta p { font-size: 13px; color: var(--text2); }
  .retry-btn {
    padding: 9px 18px;
    background: rgba(139,124,248,0.15);
    border: 1px solid rgba(139,124,248,0.3);
    border-radius: 8px;
    color: var(--accent3);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all .15s;
  }
  .retry-btn:hover { background: rgba(139,124,248,0.25); }

  /* ── NAV BUTTONS ── */
  .part-nav {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .nav-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: var(--r);
    border: 1px solid var(--border);
    background: var(--bg2);
    color: var(--text2);
    font-family: var(--font-body);
    font-size: 13.5px;
    font-weight: 500;
    cursor: pointer;
    transition: all .15s;
  }
  .nav-btn:hover { border-color: var(--border-h); color: var(--text); background: var(--bg3); }
  .nav-btn.primary {
    background: rgba(139,124,248,0.15);
    border-color: rgba(139,124,248,0.3);
    color: var(--accent3);
    margin-left: auto;
  }
  .nav-btn.primary:hover { background: rgba(139,124,248,0.25); }

  /* ── WELCOME ── */
  .welcome-screen { padding: 48px 44px; max-width: 700px; }
  .welcome-screen .big-title {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 12px;
    background: linear-gradient(135deg, var(--text) 0%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .welcome-screen .sub {
    color: var(--text2);
    font-size: 15px;
    margin-bottom: 32px;
    line-height: 1.8;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 32px;
  }
  .feat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--r2);
    padding: 18px 20px;
  }
  .feat-card .icon { font-size: 22px; margin-bottom: 8px; }
  .feat-card strong {
    display: block;
    font-family: var(--font-head);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }
  .feat-card p { font-size: 12.5px; color: var(--text3); line-height: 1.6; }
  .start-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    background: linear-gradient(135deg, var(--accent), #6d5bd4);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .15s, transform .15s;
    letter-spacing: 0.2px;
  }
  .start-btn:hover { opacity: 0.88; transform: translateY(-1px); }

  /* scrollbar */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

  /* ── DONE BADGE ── */
  .done-badge {
    width: 16px; height: 16px;
    background: var(--teal);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    color: #000;
    margin-left: auto;
    flex-shrink: 0;
    font-weight: 700;
  }
  .cat-done-badge {
    width: 16px; height: 16px;
    background: var(--teal);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    color: #000;
    flex-shrink: 0;
    font-weight: 700;
    margin-left: 4px;
  }

  @media (max-width: 700px) {
    .sidebar { display: none; }
    .content-area, .welcome-screen { padding: 24px 20px 48px; }
    .page-header { padding: 24px 20px; }
    .feature-grid { grid-template-columns: 1fr; }
    .welcome-screen .big-title { font-size: 26px; }
  }
</style>
</head>
<body>

<div class="shell">
  <!-- SIDEBAR -->
  <nav class="sidebar" id="sidebar">
    <div class="logo">
      <div class="logo-badge">BELAJAR</div>
      <h1>SQA Learn</h1>
      <p>Software Quality Assurance</p>
    </div>
    <div class="nav-section">
      <div class="nav-section-title">Materi</div>
      <div id="nav-cats"></div>
    </div>
    <div class="sidebar-footer">
      <div class="progress-label">
        <span>Progress</span>
        <span id="prog-txt">0%</span>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" id="prog-bar"></div>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main" id="main-panel">
    <!-- will be rendered by JS -->
  </div>
</div>

<!-- TOOLTIP -->
<div class="tooltip-box" id="tooltip">
  <div class="tooltip-label" id="tt-type"></div>
  <div class="tooltip-term" id="tt-term"></div>
  <div class="tooltip-def" id="tt-def"></div>
</div>

<script>
// ═══════════════════════════════════════════════
// DATA — MATERI SQA
// ═══════════════════════════════════════════════
const GLOSSARY = {
  "SQA": { type: "concept", def: "Software Quality Assurance — proses sistematis memastikan software memenuhi standar kualitas yang ditetapkan sebelum dan selama pengembangan." },
  "bug": { type: "error", def: "Kesalahan atau cacat pada kode program yang menyebabkan software tidak berjalan sesuai harapan." },
  "defect": { type: "error", def: "Ketidaksesuaian antara perilaku aktual software dengan spesifikasi yang seharusnya." },
  "test case": { type: "process", def: "Dokumen yang mendefinisikan input, kondisi eksekusi, dan hasil yang diharapkan untuk menguji suatu fungsi software." },
  "test plan": { type: "process", def: "Dokumen resmi yang menjelaskan ruang lingkup, pendekatan, sumber daya, dan jadwal aktivitas pengujian." },
  "regression testing": { type: "process", def: "Pengujian ulang software setelah ada perubahan untuk memastikan tidak ada fungsionalitas yang sebelumnya bekerja menjadi rusak." },
  "unit testing": { type: "process", def: "Pengujian pada unit/komponen terkecil dari software secara independen, biasanya dilakukan oleh developer." },
  "integration testing": { type: "process", def: "Pengujian yang memverifikasi bahwa beberapa unit/modul bekerja dengan benar saat digabungkan." },
  "black-box testing": { type: "process", def: "Metode pengujian di mana tester tidak mengetahui internal kode — hanya fokus pada input dan output." },
  "white-box testing": { type: "process", def: "Metode pengujian di mana tester mengetahui struktur internal kode dan menulis test berdasarkan logikanya." },
  "UAT": { type: "process", def: "User Acceptance Testing — pengujian oleh pengguna akhir untuk memvalidasi software sesuai kebutuhan bisnis sebelum go-live." },
  "SDLC": { type: "concept", def: "Software Development Life Cycle — tahapan proses pengembangan software dari perencanaan hingga perawatan." },
  "QA": { type: "concept", def: "Quality Assurance — aktivitas sistematis untuk memastikan proses menghasilkan produk berkualitas." },
  "QC": { type: "concept", def: "Quality Control — inspeksi dan pengujian produk akhir untuk menemukan defect." },
  "smoke testing": { type: "process", def: "Pengujian cepat untuk memastikan fungsi-fungsi dasar sistem berjalan sebelum masuk ke testing yang lebih detail." },
  "sanity testing": { type: "process", def: "Pengujian fokus untuk memverifikasi bahwa perubahan spesifik atau perbaikan bug sudah benar bekerja." },
  "automation testing": { type: "tool", def: "Pengujian menggunakan script/tools otomatis (seperti Selenium, Cypress) untuk menjalankan test case tanpa intervensi manual." },
  "manual testing": { type: "process", def: "Pengujian yang dilakukan secara langsung oleh manusia, tanpa bantuan tools otomatis." },
  "test coverage": { type: "metric", def: "Persentase kode atau fitur yang sudah dicakup oleh test case — semakin tinggi semakin baik kualitasnya." },
  "severity": { type: "metric", def: "Tingkat dampak sebuah defect terhadap fungsionalitas sistem (Critical, Major, Minor, Trivial)." },
  "priority": { type: "metric", def: "Seberapa segera sebuah defect harus diperbaiki berdasarkan kebutuhan bisnis." },
  "test environment": { type: "concept", def: "Konfigurasi hardware dan software yang dipersiapkan khusus untuk melakukan pengujian, terpisah dari production." },
  "bug life cycle": { type: "process", def: "Siklus hidup sebuah bug mulai dari ditemukan (New) → ditugaskan → diperbaiki → diverifikasi → ditutup." },
  "requirement": { type: "concept", def: "Deskripsi tertulis tentang apa yang harus dilakukan software — fondasi untuk membuat test case." },
  "test scenario": { type: "process", def: "Deskripsi high-level tentang apa yang akan diuji, lebih umum dari test case." },
  "performance testing": { type: "process", def: "Pengujian untuk mengevaluasi kecepatan, stabilitas, dan kemampuan sistem di bawah beban kerja tertentu." },
  "load testing": { type: "process", def: "Jenis performance testing yang menguji sistem dengan jumlah pengguna/transaksi yang diharapkan." },
  "stress testing": { type: "process", def: "Menguji sistem di luar kapasitas normal untuk menemukan titik kegagalannya." },
  "security testing": { type: "process", def: "Pengujian untuk menemukan celah keamanan (vulnerabilities) dalam software agar tidak bisa dieksploitasi." },
  "traceability matrix": { type: "tool", def: "Dokumen yang memetakan requirement ke test case — memastikan semua requirement sudah ada test-nya." },
  "STLC": { type: "concept", def: "Software Testing Life Cycle — serangkaian fase spesifik dalam proses pengujian software." },
  "verification": { type: "concept", def: "Memastikan software dibangun dengan benar sesuai spesifikasi (Are we building the product right?)." },
  "validation": { type: "concept", def: "Memastikan software yang dibangun adalah yang benar dan memenuhi kebutuhan pengguna (Are we building the right product?)." },
  "exploratory testing": { type: "process", def: "Pengujian tanpa skrip yang sudah ditetapkan — tester bebas mengeksplorasi software secara kreatif untuk menemukan bug." },
  "Selenium": { type: "tool", def: "Framework open-source populer untuk automation testing pada web application menggunakan berbagai bahasa pemrograman." },
  "Jira": { type: "tool", def: "Tool manajemen proyek dan bug tracking yang banyak digunakan tim QA untuk melacak defect dan test activities." },
  "API testing": { type: "process", def: "Pengujian langsung pada Application Programming Interface untuk memvalidasi fungsionalitas, keandalan, dan keamanan." },
  "Agile": { type: "concept", def: "Metodologi pengembangan software iteratif dan kolaboratif, di mana QA bekerja bersama developer sejak awal sprint." },
  "sprint": { type: "concept", def: "Periode waktu singkat (biasanya 1-2 minggu) dalam Agile di mana tim menyelesaikan sekumpulan pekerjaan." },
  "CI/CD": { type: "tool", def: "Continuous Integration/Continuous Delivery — praktik otomatisasi build, test, dan deployment software secara berkelanjutan." },
  "defect density": { type: "metric", def: "Jumlah defect per ukuran software (misalnya per 1000 baris kode) — indikator kualitas kode." },
  "MTTR": { type: "metric", def: "Mean Time To Repair — rata-rata waktu yang dibutuhkan untuk memperbaiki sebuah defect atau kegagalan sistem." },
  "boundary value analysis": { type: "process", def: "Teknik test design yang menguji nilai-nilai di batas (minimum, maksimum) dari suatu input, karena banyak bug terjadi di sana." },
  "equivalence partitioning": { type: "process", def: "Teknik membagi data input ke dalam kelas-kelas yang setara agar test case lebih efisien." },
  "test script": { type: "tool", def: "Sekumpulan instruksi (manual atau kode) yang menjelaskan langkah-langkah untuk mengeksekusi sebuah test case." },
  "retesting": { type: "process", def: "Pengujian ulang khusus pada bug yang sudah diperbaiki untuk memastikan perbaikan berhasil." },
  "test suite": { type: "tool", def: "Kumpulan test case yang dikelompokkan bersama untuk tujuan pengujian tertentu." },
  "cross-browser testing": { type: "process", def: "Pengujian untuk memastikan web application berjalan dengan baik di berbagai browser (Chrome, Firefox, Safari, dll)." },
};

const CATEGORIES = [
